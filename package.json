{
  "name": "ivyishotgirl",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000",
    "start": "run-p start:api start:fe",
    "start:api": "python -m uvicorn api.index:app --reload --port 8000",
    "start:fe": "vite --port 3000",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.3.1",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-vue-devtools": "^8.1.4",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
